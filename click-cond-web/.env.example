# Banco MySQL (Railway)
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@host:3306/dbname"

# JWT — autenticação de porteiros / mobile
JWT_SECRET="troque-por-um-segredo-forte-min-32-chars"
JWT_EXPIRES_IN="1d"

# CORS — origens permitidas (separadas por vírgula)
# Em produção, inclua o domínio Vercel e o domínio personalizado.
CORS_ORIGINS="http://localhost:4200,https://click-prestare.vercel.app"

# Porta da API
PORT=3000

# E-mail — envio de credenciais e recuperação de senha
# Opcao 1 (RECOMENDADA): Resend HTTP API
#   - Cadastre em resend.com e pegue a API key
#   - Funciona em qualquer ambiente (sem problema de portas/IPv6)
RESEND_API_KEY="re_xxx..."
MAIL_FROM="onboarding@resend.dev"  # ou seu dominio verificado em Resend
MAIL_FROM_NAME="Click Condomínios"

# Opcao 2 (FALLBACK): SMTP via Gmail App Password
# Usado automaticamente se RESEND_API_KEY nao estiver setado.
# Pode falhar em hosts que bloqueiam portas SMTP (ex: Railway hobby).
SMTP_SERVICE="gmail"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-app-password-do-gmail"
SMTP_FROM="seu-email@gmail.com"
SMTP_FROM_NAME="Click Condomínios"
